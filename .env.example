# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── GitHub App ───────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=              # PEM private key (use literal \n for newlines)
GITHUB_WEBHOOK_SECRET=

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.2
OPENAI_TOP_P=1
OPENAI_N=1
OPENAI_FREQUENCY_PENALTY=0
OPENAI_PRESENCE_PENALTY=0
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── OpenAI Analysis Limits ──────────────────────────────
OPENAI_FILE_CONTENT_SIZE_LIMIT=16000
OPENAI_TOTAL_FILES_LIMIT=8
OPENAI_BYPASS_LARGE_FILES=true

# ─── Cache & Embeddings ─────────────────────────────────
OPENAI_ENABLE_CACHE=true
OPENAI_ENABLE_EMBEDDINGS=true
OPENAI_VECTOR_DB_TOP_K=5

# ─── Repo Context ───────────────────────────────────────
REPO_CONTEXT_FILE_LIMIT=15
REPO_CONTEXT_SIZE_LIMIT=32000

# ─── Pinecone (Vector DB) ───────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
