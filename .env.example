# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── GitHub App ───────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=              # PEM private key (use literal \n for newlines)
GITHUB_WEBHOOK_SECRET=

# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.2
OPENAI_TOP_P=1
OPENAI_N=1
OPENAI_FREQUENCY_PENALTY=0
OPENAI_PRESENCE_PENALTY=0
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── OpenAI Analysis Limits ──────────────────────────────
OPENAI_FILE_CONTENT_SIZE_LIMIT=16000
OPENAI_TOTAL_FILES_LIMIT=8
OPENAI_BYPASS_LARGE_FILES=true

# ─── Cache & Embeddings ─────────────────────────────────
OPENAI_ENABLE_CACHE=true
OPENAI_ENABLE_EMBEDDINGS=true
OPENAI_VECTOR_DB_TOP_K=5

# ─── Repo Context ───────────────────────────────────────
REPO_CONTEXT_FILE_LIMIT=15
REPO_CONTEXT_SIZE_LIMIT=32000

# ─── Custom Review Rules ────────────────────────────────
# Global rules applied to every repo (newline-separated).
# Per-repo rules go in a .prism-rules file at the repo root.
PRISM_GLOBAL_RULES="Do not flag missing error handling if a try/catch, .catch(), or error callback already wraps the code.\nDo not report bugs in standard language behavior such as type coercion, optional chaining, nullish coalescing, or well-known runtime semantics.\nNever flag correct usage of a library or framework API — only flag usage that contradicts official documentation.\nDo not suggest adding input validation when the input is already validated by an upstream caller, middleware, or schema.\nDo not flag performance concerns unless the code is in a demonstrably hot path such as a tight loop or recursive call.\nIgnore stylistic and naming preferences — only flag names that are actively misleading or that shadow important variables.\nDo not speculate about issues in code that is not shown in the diff or the provided context."

# ─── Pinecone (Vector DB) ───────────────────────────────
PINECONE_API_KEY=
PINECONE_INDEX_NAME=
